#!/usr/bin/env node

const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');

const args = process.argv.slice(2);

let file = null;
let fallback = null;
let showHelp = false;

for (let i = 0; i < args.length; i++) {
  const a = args[i];
  if (a === '-h' || a === '--help') {
    showHelp = true;
  } else if (a === '--fallback') {
    fallback = args[++i];
  } else if (!a.startsWith('-') && file === null) {
    file = a;
  }
}

if (showHelp || !file) {
  console.error('Usage: mdexec <file.md> [--fallback <file.md>]');
  console.error('');
  console.error('Replaces !`cmd` in markdown with command output.');
  console.error('');
  console.error('Resolution:');
  console.error('  Paths with a ".claude" segment: try CWD/<path>, then $HOME/<path>.');
  console.error('  Other relative paths: resolve against CWD.');
  console.error('  Absolute paths: used as-is.');
  console.error('  If the primary file is missing and --fallback is given, the fallback');
  console.error('  is resolved with the same rules.');
  process.exit(1);
}

function resolveFile(f) {
  if (path.isAbsolute(f)) {
    return fs.existsSync(f) ? f : null;
  }
  const segments = f.split('/');
  if (segments.includes('.claude')) {
    const cwdPath = path.resolve(process.cwd(), f);
    if (fs.existsSync(cwdPath)) return cwdPath;
    const homePath = path.resolve(os.homedir(), f);
    if (fs.existsSync(homePath)) return homePath;
    return null;
  }
  const p = path.resolve(process.cwd(), f);
  return fs.existsSync(p) ? p : null;
}

let resolved = resolveFile(file);
if (!resolved && fallback) {
  resolved = resolveFile(fallback);
}

if (!resolved) {
  const suffix = fallback ? ` (fallback: ${fallback})` : '';
  console.error(`mdexec: file not found: ${file}${suffix}`);
  process.exit(1);
}

const content = fs.readFileSync(resolved, 'utf-8');
const cwd = process.cwd();

const result = content.replace(/!`([^`\n]+)`/g, (_, cmd) => {
  try {
    return execSync(cmd, { encoding: 'utf-8', cwd, stdio: ['pipe', 'pipe', 'inherit'] }).replace(/\n$/, '');
  } catch (e) {
    const code = e.status || 1;
    console.error(`mdexec: command failed (exit ${code}): ${cmd}`);
    return '';
  }
});

process.stdout.write(result);
