#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["requests"]
# ///
"""Tracker-agnostic dispatcher for task-system operations.

Resolves `task-system` from <repo>/project-config.toml first, then
~/.config/tasks/config.toml, defaulting to "jira". Dispatches each
subcommand to the active backend. Skills consume this script; they never
name a backend directly.

Runs inside or outside a git repo. Auth is global: JIRA_API_TOKEN from
env, else macOS keychain via
`security find-generic-password -s jira-api-token -a $USER -w`.

Errors go to STDOUT. Format depends on stdout:
- TTY (human at a terminal): `\033[31;1mError:\033[0m <msg>` (colored, no brackets)
- Pipe / $() capture / mdexec: `[[Error: <msg>]]` (marker form,
  matched by callers so $()-captured errors don't get swallowed).
Progress chatter goes to STDERR.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import tempfile
import time
import tomllib
from dataclasses import dataclass, field
from datetime import datetime
from pathlib import Path
from shutil import which
from typing import Any, NoReturn
from urllib.parse import quote

import requests

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

PHASES = ["Requirements", "Plan", "Code", "Close", "Done"]
# WARNING: changing LINEAR_MARKER_PREFIX silently breaks phase tracking for
# any repo still on `task-system = "linear"` - old comments use the old prefix,
# new writes use the new one, and flow-progress-get sees nothing.
LINEAR_MARKER_PREFIX = "AI-Workflow: phase="
JIRA_FIELD_NAME = "AI Workflow"
JIRA_CONFIG = Path.home() / ".config/.jira/.config.yml"
GLOBAL_CONFIG_FILE = Path.home() / ".config/tasks/config.toml"
KEYCHAIN_SERVICE = os.environ.get("TASKS_KEYCHAIN_SERVICE", "jira-api-token")
FIELD_CACHE_DIR = Path.home() / ".cache/ai-enablement"
FIELD_CACHE_FILE = FIELD_CACHE_DIR / "jira-fields.json"
FIELD_CACHE_TTL = 86400  # 24h
EPIC_CACHE_TTL = 86400
VALID_ISSUE_TYPES = ["Task", "Sub-task", "Bug", "Story", "Epic"]

# Canonical status name -> JIRA status. Canonical names match those used by
# `tasks set-state` callers and the g-flow skills.
JIRA_STATUS_MAP = {
    "Backlog": "Backlog",
    "Todo": "To Do",
    "In Progress": "In Progress",
    "In Review": "Review",
    "Done": "Done",
    "Cancelled": "Cancelled",
    "Canceled": "Cancelled",
}

KEY_RE = re.compile(r"[A-Z]+-[0-9]+")
KEY_END_RE = re.compile(r"[A-Z]+-[0-9]+$")

# Workflow order for `tasks list`: active work first, backlog last. Statuses
# not in this list sort after all of these (in their newest-first order).
# JQL can't express this ordinal ordering, so we sort rows in Python.
STATUS_SORT_ORDER = ["In Progress", "In Review", "Review", "To Do", "Backlog"]

# ---------------------------------------------------------------------------
# Error machinery
# ---------------------------------------------------------------------------


def die(msg: str) -> NoReturn:
    # Mirror the bash contract: errors go to STDOUT, colored on a TTY and in
    # the `[[Error: ...]]` marker form otherwise (so $()-captured errors
    # surface to callers instead of being swallowed).
    if sys.stdout.isatty():
        print(f"\033[31;1mError:\033[0m {msg}")
    else:
        print(f"[[Error: {msg}]]")
    sys.exit(1)


def warn(msg: str) -> None:
    print(f"warning: {msg}", file=sys.stderr)


def log(msg: str) -> None:
    print(msg, file=sys.stderr)

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------


@dataclass
class Config:
    task_system: str
    repo_root: Path | None
    jira_site: str | None = None
    _jira: "JiraClient | None" = field(default=None, repr=False)

    @property
    def jira(self) -> "JiraClient":
        if self.task_system != "jira":
            die(f"this subcommand is JIRA-only (current task-system={self.task_system})")
        if self._jira is None:
            if not self.jira_site:
                die(f"JIRA site not configured (missing {JIRA_CONFIG}); run 'jira init' first")
            user = _yaml_scalar(JIRA_CONFIG, "login")
            if not user:
                die(f"could not read 'login' from {JIRA_CONFIG}")
            self._jira = JiraClient(site=self.jira_site, user=user)
        return self._jira


def load_config() -> Config:
    # Repo root is optional - the script also runs outside a project (config
    # falls back to ~/.config/tasks/config.toml; auth falls back to the macOS
    # keychain). Repo-only subcommands (plan, branch-derived KEYs) enforce
    # the repo requirement themselves.
    repo_root: Path | None = None
    try:
        out = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"],
            stderr=subprocess.DEVNULL, text=True)
        repo_root = Path(out.strip())
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    # Resolve task-system: project-config.toml > ~/.config/tasks/config.toml > "jira".
    task_system = ""
    cfg_source = "default"
    if repo_root:
        cfg_path = repo_root / "project-config.toml"
        if cfg_path.is_file():
            with cfg_path.open("rb") as fh:
                data = tomllib.load(fh)
            ts = data.get("task-system")
            if ts:
                task_system = str(ts)
                cfg_source = str(cfg_path)
    if not task_system and GLOBAL_CONFIG_FILE.is_file():
        with GLOBAL_CONFIG_FILE.open("rb") as fh:
            data = tomllib.load(fh)
        ts = data.get("task-system")
        if ts:
            task_system = str(ts)
            cfg_source = str(GLOBAL_CONFIG_FILE)
    if not task_system:
        task_system = "jira"

    if task_system not in ("jira", "linear"):
        die(f"unknown task-system '{task_system}' in {cfg_source} (expected 'jira' or 'linear')")

    jira_site: str | None = None
    if task_system == "jira" and JIRA_CONFIG.is_file():
        jira_site = _yaml_scalar(JIRA_CONFIG, "server")

    return Config(task_system=task_system, repo_root=repo_root, jira_site=jira_site)


def _yaml_scalar(path: Path, key: str) -> str | None:
    """Read a top-level (`key:`) or one-level-nested (`parent.child:`) scalar.

    Just enough for ~/.config/.jira/.config.yml — no full parser needed.
    """
    text = path.read_text()
    if "." not in key:
        m = re.search(rf"^{re.escape(key)}:\s*(.*?)\s*$", text, re.MULTILINE)
        if not m:
            return None
        return _strip_yaml_quotes(m.group(1))
    parent, child = key.split(".", 1)
    in_block = False
    for line in text.splitlines():
        if re.match(rf"^{re.escape(parent)}:", line):
            in_block = True
            continue
        if in_block and line and not line[0].isspace():
            in_block = False
        if in_block:
            m = re.match(rf"^\s+{re.escape(child)}:\s*(.*?)\s*$", line)
            if m:
                return _strip_yaml_quotes(m.group(1))
    return None


def _strip_yaml_quotes(s: str) -> str:
    if len(s) >= 2 and s[0] == s[-1] and s[0] in ("'", '"'):
        return s[1:-1]
    return s

# ---------------------------------------------------------------------------
# Branch / key helpers
# ---------------------------------------------------------------------------


def current_branch() -> str | None:
    try:
        out = subprocess.check_output(
            ["git", "branch", "--show-current"],
            stderr=subprocess.DEVNULL, text=True).strip()
    except subprocess.CalledProcessError:
        return None
    return out or None


def branch_key() -> str | None:
    b = current_branch()
    if not b:
        return None
    # Anchor to end-of-string to match the `<slug>-<KEY>` convention -
    # an unanchored match would pick the wrong key on branches whose slug
    # contains a key-like substring (e.g. `migrate-DRV-99-to-AIE-125`).
    m = KEY_END_RE.search(b)
    return m.group(0) if m else None


def require_key(key: str | None) -> str:
    if key:
        return key
    k = branch_key()
    if k:
        return k
    branch = current_branch()
    if branch is None:
        die("no issue key provided and not inside a git repository - pass KEY explicitly")
    die(f"no issue key provided and could not derive from branch '{branch}'")


def slugify(s: str) -> str:
    s = s.lower()
    s = re.sub(r"[^a-z0-9]+", "-", s).strip("-")
    return s[:50].rstrip("-")


def is_key(s: str) -> bool:
    return bool(KEY_RE.fullmatch(s))

# ---------------------------------------------------------------------------
# Token resolution + jira-cli shell-out
# ---------------------------------------------------------------------------


def _keychain_token() -> str | None:
    """Read JIRA token from the macOS keychain. Returns None when unavailable.

    Used as the global auth path: one `security add-generic-password` per
    machine and every `tasks` invocation finds the token, no shell-init or
    repo-loaded env required.
    """
    if sys.platform != "darwin":
        return None
    if not which("security"):
        return None
    user = os.environ.get("USER") or ""
    if not user:
        return None
    try:
        out = subprocess.check_output(
            ["security", "find-generic-password",
             "-s", KEYCHAIN_SERVICE, "-a", user, "-w"],
            stderr=subprocess.DEVNULL, text=True).strip()
    except subprocess.CalledProcessError:
        return None
    return out or None


def load_jira_token() -> str:
    """Resolve JIRA API token. Order: JIRA_API_TOKEN env -> macOS keychain.

    On success, the value is also written back into os.environ["JIRA_API_TOKEN"]
    so `jira-cli` shell-outs pick it up without a second lookup.
    """
    tok = os.environ.get("JIRA_API_TOKEN")
    if tok:
        return tok
    tok = _keychain_token()
    if tok:
        os.environ["JIRA_API_TOKEN"] = tok
        return tok
    die(
        "JIRA_API_TOKEN not available. Set up one of:\n"
        f"  - macOS keychain (recommended): security add-generic-password -s {KEYCHAIN_SERVICE} -a $USER -w '<TOKEN>'\n"
        "  - Shell env: export JIRA_API_TOKEN=<TOKEN>")


def jira_cli(cfg: Config, args: list[str], *, stdin: str | None = None,
             capture: bool = False) -> subprocess.CompletedProcess:
    """Invoke the `jira` (jira-cli) binary with JIRA_API_TOKEN resolved."""
    if not which("jira"):
        die("jira-cli not installed - brew install ankitpokhrel/jira-cli/jira-cli")
    load_jira_token()  # ensures os.environ["JIRA_API_TOKEN"] is set
    return subprocess.run(
        ["jira", *args], input=stdin, text=True,
        capture_output=capture, check=False)

# ---------------------------------------------------------------------------
# JIRA REST client
# ---------------------------------------------------------------------------


class JiraClient:
    """Authenticated JIRA REST + multipart client.

    Token comes from `load_jira_token()` (env -> macOS keychain).
    """

    def __init__(self, site: str, user: str):
        self.site = site.rstrip("/")
        self.user = user
        self._token: str | None = None
        self._session: requests.Session | None = None

    @property
    def token(self) -> str:
        if self._token is None:
            self._token = load_jira_token()
        return self._token

    @property
    def session(self) -> requests.Session:
        if self._session is None:
            s = requests.Session()
            s.auth = (self.user, self.token)
            s.headers["Accept"] = "application/json"
            self._session = s
        return self._session

    def request(self, method: str, path: str, *, json_body: Any = None,
                raw_body: str | None = None) -> Any:
        url = f"{self.site}{path}"
        headers: dict[str, str] = {}
        data = None
        if json_body is not None:
            headers["Content-Type"] = "application/json"
            data = json.dumps(json_body)
        elif raw_body is not None:
            headers["Content-Type"] = "application/json"
            data = raw_body
        r = self.session.request(method, url, data=data, headers=headers)
        if not r.ok:
            die(f"HTTP {r.status_code}: {r.text}")
        if not r.content:
            return None
        try:
            return r.json()
        except ValueError:
            return r.text

    def get(self, path: str) -> Any:
        return self.request("GET", path)

    def post(self, path: str, body: Any = None) -> Any:
        return self.request("POST", path, json_body=body)

    def put(self, path: str, body: Any = None) -> Any:
        return self.request("PUT", path, json_body=body)

    def attach(self, key: str, file_path: Path) -> bool:
        url = f"{self.site}/rest/api/3/issue/{key}/attachments"
        with file_path.open("rb") as fh:
            r = requests.post(
                url, auth=(self.user, self.token),
                headers={"X-Atlassian-Token": "no-check",
                         "Accept": "application/json"},
                files={"file": (file_path.name, fh)})
        if not r.ok:
            warn(f"attach {file_path} -> {key} failed: HTTP {r.status_code}: {r.text}")
            return False
        return True

    def field_id(self, name: str) -> str:
        FIELD_CACHE_DIR.mkdir(parents=True, exist_ok=True)
        if not _cache_fresh(FIELD_CACHE_FILE, FIELD_CACHE_TTL):
            log("refreshing JIRA field cache...")
            data = self.get("/rest/api/3/field")
            if not isinstance(data, list):
                preview = json.dumps(data)[:200]
                die(f"JIRA field list response is not a JSON array: {preview}")
            FIELD_CACHE_FILE.write_text(json.dumps(data))
        fields = json.loads(FIELD_CACHE_FILE.read_text())
        for f in fields:
            if f.get("name") == name:
                return f["id"]
        die(f"JIRA custom field '{name}' not found - ask admin to create it")

    def project_key(self) -> str:
        if not JIRA_CONFIG.is_file():
            die(f"JIRA config not found at {JIRA_CONFIG}; run 'jira init' first")
        key = _yaml_scalar(JIRA_CONFIG, "project.key")
        if not key:
            die(f"could not read 'project.key' from {JIRA_CONFIG}")
        return key

    def epic_cache_path(self) -> Path:
        return FIELD_CACHE_DIR / f"jira-epics-{self.project_key()}.json"

    def epic_cache_load(self, force: bool = False) -> None:
        FIELD_CACHE_DIR.mkdir(parents=True, exist_ok=True)
        cache = self.epic_cache_path()
        if not force and _cache_fresh(cache, EPIC_CACHE_TTL):
            return
        log("refreshing JIRA epic cache...")
        # statusCategory != Done excludes both Done and Cancelled.
        jql = f"project = {self.project_key()} AND issuetype = Epic AND statusCategory != Done"
        # `/rest/api/3/search` was removed (HTTP 410); use /search/jql.
        response = self.get(
            f"/rest/api/3/search/jql?jql={quote(jql)}&fields=summary&maxResults=100")
        issues = response.get("issues") if isinstance(response, dict) else None
        if not isinstance(issues, list):
            die(f"JIRA epic search response missing .issues[]: {json.dumps(response)[:200]}")
        epics = [{"key": i["key"], "summary": i["fields"]["summary"]} for i in issues]
        cache.write_text(json.dumps(epics))

    def load_epics(self, force: bool = False) -> list[dict[str, str]]:
        self.epic_cache_load(force)
        return json.loads(self.epic_cache_path().read_text())


def _cache_fresh(path: Path, ttl_seconds: int) -> bool:
    if not path.is_file():
        return False
    return (time.time() - path.stat().st_mtime) < ttl_seconds

# ---------------------------------------------------------------------------
# Title fetch (shared)
# ---------------------------------------------------------------------------


def title_for_key(cfg: Config, key: str) -> str:
    if cfg.task_system == "jira":
        # REST is more reliable than parsing `jira issue view --plain`,
        # whose pretty-printed layout doesn't carry a `Summary` label.
        resp = cfg.jira.get(f"/rest/api/3/issue/{key}?fields=summary")
        if not isinstance(resp, dict):
            return ""
        return str(resp.get("fields", {}).get("summary", "") or "")
    # linear
    try:
        out = subprocess.check_output(
            ["linear", "issues", "get", key],
            stderr=subprocess.DEVNULL, text=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""
    first = out.splitlines()[0] if out else ""
    return re.sub(rf"^{re.escape(key)}:\s*", "", first)

# ---------------------------------------------------------------------------
# Epic / parent resolution
# ---------------------------------------------------------------------------


def resolve_parent_fuzzy(cfg: Config, query: str) -> str:
    """Match `query` (case-insensitive substring) against cached epic
    .summary. Returns the matching KEY; dies on zero / multiple matches.
    """
    epics = cfg.jira.load_epics()
    q = query.lower()
    matches = [e for e in epics if q in e["summary"].lower()]
    if not matches:
        die(f"--parent '{query}' did not match any cached epic summary. Run 'tasks epics' to see the list.")
    if len(matches) == 1:
        return matches[0]["key"]
    listing = "\n".join(f"  {m['key']}\t{m['summary']}" for m in matches)
    die(f"--parent '{query}' matched multiple epics; be more specific or pass the KEY directly:\n{listing}")


def resolve_default_parent(cfg: Config) -> str:
    epics = cfg.jira.load_epics()
    if not epics:
        die("create: no epics found in cache; create one in JIRA first (or pass --parent KEY)")
    if len(epics) == 1:
        return epics[0]["key"]
    listing = "\n".join(f"  {e['key']}  {e['summary']}" for e in epics)
    die(f"create: multiple epics in cache; pass --parent KEY. Available:\n{listing}")

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------


def cmd_show(cfg: Config, args: argparse.Namespace) -> None:
    key = require_key(args.key)
    if cfg.task_system == "linear":
        subprocess.run(["linear", "issues", "get", key], check=False)
    else:
        _print_jira_parent(cfg, key)
        # Suppress jira-cli's verbose multi-line comment block; we render
        # comments ourselves below in a compact one-line-each form.
        jira_cli(cfg, ["issue", "view", key, "--plain", "--comments", "0"])
        _print_jira_comments(cfg, key)


def _print_jira_parent(cfg: Config, key: str) -> None:
    """Print a `Parent: KEY - SUMMARY` line. `jira issue view --plain` omits
    the parent entirely, so fetch it over REST and surface it ourselves.
    """
    resp = cfg.jira.get(f"/rest/api/3/issue/{key}?fields=parent")
    fields = resp.get("fields", {}) if isinstance(resp, dict) else {}
    parent = fields.get("parent")
    if not parent:
        return
    pkey = parent.get("key", "")
    psummary = (parent.get("fields") or {}).get("summary", "")
    print(f"Parent: {pkey} - {psummary}")
    # Flush before the jira-cli subprocess writes to the same fd - otherwise
    # Python's buffered line lands *after* the issue view when stdout is piped.
    sys.stdout.flush()


def _print_jira_comments(cfg: Config, key: str, limit: int = 50) -> None:
    """Render comments one per line: `[<relative-date>] <First-Name>: <body>`.

    Replaces jira-cli's multi-line-per-comment block (suppressed via
    `--comments 0`) with a compact, scannable form. Oldest first.
    """
    resp = cfg.jira.get(f"/rest/api/3/issue/{key}/comment?maxResults={limit}")
    comments = resp.get("comments", []) if isinstance(resp, dict) else []
    if not comments:
        return
    # Separator mirrors jira-cli's own `------ Description ------` divider.
    print()
    print("------------------------ Comments ------------------------")
    print()
    for c in comments:
        author = (c.get("author") or {}).get("displayName") or "?"
        first = author.split()[0]
        when = _relative_time(c.get("created", ""))
        body = re.sub(r"\s+", " ", _adf_to_text(c.get("body"))).strip()
        print(f"[{when}] {first}: {body}")
    sys.stdout.flush()


def _adf_to_text(node: Any) -> str:
    """Flatten an Atlassian Document Format node to plain text."""
    if isinstance(node, str):
        return node
    if isinstance(node, list):
        return "".join(_adf_to_text(n) for n in node)
    if not isinstance(node, dict):
        return ""
    ntype = node.get("type")
    if ntype == "text":
        return node.get("text", "")
    if ntype == "hardBreak":
        return "\n"
    if ntype == "mention":
        return (node.get("attrs") or {}).get("text", "")
    if ntype == "inlineCard":
        return (node.get("attrs") or {}).get("url", "")
    text = _adf_to_text(node.get("content"))
    # Block-level nodes get a trailing newline so paragraphs / list items
    # don't run together (later collapsed to spaces for one-line display).
    if ntype in ("paragraph", "heading", "blockquote", "listItem", "codeBlock"):
        text += "\n"
    return text


# ---------------------------------------------------------------------------
# ADF -> Markdown (round-trip for get-description / set-description)
# ---------------------------------------------------------------------------
# `_adf_to_text` flattens to one-liner plain text for compact display. The
# pair below preserves structure (headings, bold/italic/code, links, nested
# lists, code blocks) so a description fetched with `get-description` can be
# edited and re-applied with `set-description` (which feeds the markdown back
# through jira-cli's own markdown -> ADF conversion) without losing shape.


def _adf_inline(node: Any) -> str:
    """Render text-level ADF (text, marks, mentions, links) to inline markdown."""
    if isinstance(node, str):
        return node
    if isinstance(node, list):
        return "".join(_adf_inline(n) for n in node)
    if not isinstance(node, dict):
        return ""
    ntype = node.get("type")
    if ntype == "text":
        text = node.get("text", "")
        for mark in node.get("marks", []):
            mtype = mark.get("type")
            if mtype == "code":
                text = f"`{text}`"
            elif mtype == "strong":
                text = f"**{text}**"
            elif mtype == "em":
                text = f"*{text}*"
            elif mtype == "strike":
                text = f"~~{text}~~"
            elif mtype == "link":
                href = (mark.get("attrs") or {}).get("href", "")
                text = f"[{text}]({href})"
        return text
    if ntype == "hardBreak":
        return "\n"
    if ntype == "mention":
        return (node.get("attrs") or {}).get("text", "")
    if ntype == "inlineCard":
        return (node.get("attrs") or {}).get("url", "")
    if ntype == "emoji":
        attrs = node.get("attrs") or {}
        return attrs.get("text") or attrs.get("shortName", "")
    return _adf_inline(node.get("content"))


def _adf_list_md(node: Any, indent: int) -> str:
    """Render a bulletList/orderedList to markdown lines (no surrounding blanks)."""
    ordered = node.get("type") == "orderedList"
    pad = "  " * indent
    lines: list[str] = []
    n = 1
    for item in node.get("content", []) or []:
        if not isinstance(item, dict) or item.get("type") != "listItem":
            continue
        marker = f"{n}. " if ordered else "- "
        first = True
        for block in item.get("content", []) or []:
            btype = block.get("type") if isinstance(block, dict) else None
            if btype in ("bulletList", "orderedList"):
                lines.append(_adf_list_md(block, indent + 1))
            elif btype == "paragraph":
                txt = _adf_inline(block.get("content"))
                if first:
                    lines.append(pad + marker + txt)
                    first = False
                else:
                    lines.append(pad + "  " + txt)
            else:
                rendered = _adf_block_md(block, indent + 1)
                if rendered:
                    lines.append(rendered)
        if first:  # empty list item
            lines.append(pad + marker)
        n += 1
    return "\n".join(lines)


def _adf_block_md(node: Any, indent: int = 0) -> str:
    """Render a single block-level ADF node to a markdown string (may be multiline)."""
    if not isinstance(node, dict):
        return ""
    ntype = node.get("type")
    pad = "  " * indent
    if ntype == "paragraph":
        return pad + _adf_inline(node.get("content"))
    if ntype == "heading":
        level = (node.get("attrs") or {}).get("level", 1)
        return "#" * int(level) + " " + _adf_inline(node.get("content"))
    if ntype == "codeBlock":
        lang = (node.get("attrs") or {}).get("language", "") or ""
        return f"```{lang}\n{_adf_inline(node.get('content'))}\n```"
    if ntype == "blockquote":
        inner = "\n\n".join(
            _adf_block_md(c, indent) for c in node.get("content", []) or [])
        return "\n".join("> " + ln for ln in inner.split("\n"))
    if ntype == "rule":
        return "---"
    if ntype in ("bulletList", "orderedList"):
        return _adf_list_md(node, indent)
    text = _adf_inline(node.get("content"))
    return (pad + text) if text else ""


def adf_to_markdown(doc: Any) -> str:
    """Convert an ADF description document to markdown. Empty string if blank."""
    if not isinstance(doc, dict):
        return ""
    parts = [_adf_block_md(n, 0) for n in doc.get("content", []) or []]
    parts = [p for p in parts if p]
    return "\n\n".join(parts)


def _relative_time(iso: str) -> str:
    """Format a JIRA ISO timestamp as a coarse relative age (e.g. `3 days ago`)."""
    if not iso:
        return "?"
    try:
        dt = datetime.strptime(iso, "%Y-%m-%dT%H:%M:%S.%f%z")
    except ValueError:
        return iso
    secs = max(0.0, (datetime.now(dt.tzinfo) - dt).total_seconds())
    mins, hours, days = secs / 60, secs / 3600, secs / 86400
    if secs < 90:
        return "just now"
    if mins < 60:
        n = round(mins)
        return f"{n} minute{'s' if n != 1 else ''} ago"
    if hours < 24:
        n = round(hours)
        return f"{n} hour{'s' if n != 1 else ''} ago"
    if days < 2:
        return "yesterday"
    if days < 30:
        return f"{int(days)} days ago"
    if days < 365:
        n = int(days / 30)
        return f"{n} month{'s' if n != 1 else ''} ago"
    n = int(days / 365)
    return f"{n} year{'s' if n != 1 else ''} ago"


def cmd_comment(cfg: Config, args: argparse.Namespace) -> None:
    # `tasks comment BODY` (no KEY) -> derive KEY from current branch.
    # `tasks comment KEY BODY` -> explicit.
    positionals = list(args.args)
    if positionals and is_key(positionals[0]):
        key = positionals.pop(0)
    else:
        key = require_key(None)

    if args.from_file:
        p = Path(args.from_file)
        if not p.is_file():
            die("comment: --from-file requires an existing file path")
        body = p.read_text()
    else:
        if not positionals:
            die("comment: missing BODY (or use --from-file PATH)")
        body = positionals[0]

    if cfg.task_system == "linear":
        subprocess.run(
            ["linear", "issues", "comment", key, "--body", body], check=False)
    else:
        jira_cli(cfg, ["issue", "comment", "add", key,
                       "--template", "-", "--no-input"], stdin=body + "\n")


def cmd_get_description(cfg: Config, args: argparse.Namespace) -> None:
    """Print the issue's current description as markdown (for read-before-edit)."""
    key = require_key(args.key)
    if cfg.task_system == "linear":
        die("get-description: not yet implemented for linear backend (TBD)")
    resp = cfg.jira.get(f"/rest/api/3/issue/{key}?fields=description")
    fields = resp.get("fields", {}) if isinstance(resp, dict) else {}
    md = adf_to_markdown(fields.get("description"))
    if md:
        print(md)


def cmd_set_description(cfg: Config, args: argparse.Namespace) -> None:
    """Replace the issue's description from a markdown body (inline or --from-file).

    The body REPLACES the whole description. Callers should fetch the current
    description first (`tasks get-description KEY`), fold in their changes, then
    pass the complete markdown here. The markdown -> ADF conversion is handled
    by jira-cli, so headings/lists/inline formatting round-trip cleanly.
    """
    positionals = list(args.args)
    if positionals and is_key(positionals[0]):
        key = positionals.pop(0)
    else:
        key = require_key(None)

    if args.from_file:
        p = Path(args.from_file)
        if not p.is_file():
            die("set-description: --from-file requires an existing file path")
        body = p.read_text()
    else:
        if not positionals:
            die("set-description: missing BODY (or use --from-file PATH)")
        body = positionals[0]

    if not body.strip():
        die("set-description: refusing to write an empty description")

    if cfg.task_system == "linear":
        die("set-description: not yet implemented for linear backend (TBD)")

    # jira-cli `issue edit` reads the description body from stdin under
    # --no-input and converts markdown -> ADF for free. Other fields (summary,
    # status, etc.) are left untouched.
    r = jira_cli(cfg, ["issue", "edit", key, "--no-input"],
                 stdin=body if body.endswith("\n") else body + "\n",
                 capture=True)
    combined = (r.stdout or "") + (r.stderr or "")
    if r.returncode != 0:
        die(f"set-description: jira-cli failed: {combined.strip()}")
    if sys.stdout.isatty():
        print(f"{cfg.jira_site.rstrip('/')}/browse/{key}")
    else:
        print(key)


def cmd_set_state(cfg: Config, args: argparse.Namespace) -> None:
    # `tasks set-state STATE` (no KEY) -> derive from current branch.
    positionals = list(args.args)
    if positionals and is_key(positionals[0]):
        key = positionals.pop(0)
    else:
        key = require_key(None)
    if not positionals:
        die("set-state: usage: tasks set-state [KEY] STATE")
    state = positionals[0]

    if cfg.task_system == "linear":
        subprocess.run(
            ["linear", "issues", "update", key, "--state", state], check=False)
        return

    target = JIRA_STATUS_MAP.get(state, state)
    r = jira_cli(cfg, ["issue", "move", key, target], capture=True)
    if r.returncode == 0:
        if r.stdout:
            sys.stdout.write(r.stdout)
        return
    log(f"direct transition to '{target}' failed; trying multi-hop walker...")
    _jira_multi_hop_move(cfg, key, target)


def _jira_multi_hop_move(cfg: Config, key: str, target: str) -> None:
    """Walk up to 2 transitions to reach the target status."""
    transitions = cfg.jira.get(f"/rest/api/3/issue/{key}/transitions")
    hop_names = [t["to"]["name"] for t in transitions.get("transitions", [])]
    for intermediate in hop_names:
        if not intermediate:
            continue
        r1 = jira_cli(cfg, ["issue", "move", key, intermediate], capture=True)
        if r1.returncode != 0:
            continue
        r2 = jira_cli(cfg, ["issue", "move", key, target], capture=True)
        if r2.returncode == 0:
            return
    die(f"could not transition {key} to '{target}' in <=2 hops")


def cmd_flow_progress_get(cfg: Config, args: argparse.Namespace) -> None:
    # Soft key resolution: unlike other commands, a missing/underivable key is
    # not an error here. It just means the flow hasn't been started against a
    # tracked issue yet, so there is no recorded phase. Echo empty - callers
    # (e.g. start-flow) map empty to the first phase and begin fresh.
    key = args.key or branch_key()
    if not key:
        return
    if cfg.task_system == "linear":
        _flow_progress_get_linear(key)
    else:
        _flow_progress_get_jira(cfg, key)


def _flow_progress_get_linear(key: str) -> None:
    # `linear issues comments` emits newest-first; first marker we find is current.
    # Anchor on a leading boundary (start-of-line or whitespace) so a stray paste
    # of the prefix inside another comment doesn't false-match.
    try:
        out = subprocess.check_output(
            ["linear", "issues", "comments", key],
            stderr=subprocess.DEVNULL, text=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return
    marker_re = re.compile(
        rf"(?:^|\s){re.escape(LINEAR_MARKER_PREFIX)}([A-Za-z]+)", re.MULTILINE)
    m = marker_re.search(out)
    if m:
        print(m.group(1))


def _flow_progress_get_jira(cfg: Config, key: str) -> None:
    fid = cfg.jira.field_id(JIRA_FIELD_NAME)
    resp = cfg.jira.get(f"/rest/api/3/issue/{key}?fields={fid}")
    fields = resp.get("fields", {}) if isinstance(resp, dict) else {}
    val = fields.get(fid)
    if val is None:
        return
    # JIRA returns the value as either an object ({value: "Plan", ...}) or a scalar.
    if isinstance(val, dict):
        v = val.get("value", "")
    else:
        v = val
    if v and v != "null":
        print(v)


def cmd_flow_progress_set(cfg: Config, args: argparse.Namespace) -> None:
    positionals = list(args.args)
    if positionals and is_key(positionals[0]):
        key = positionals.pop(0)
    else:
        key = require_key(None)
    if not positionals:
        die("flow-progress-set: usage: tasks flow-progress-set [KEY] PHASE")
    phase = positionals[0]
    if phase not in PHASES:
        die(f"flow-progress-set: unknown PHASE '{phase}' (expected one of: {' '.join(PHASES)})")

    if cfg.task_system == "linear":
        subprocess.run(["linear", "issues", "comment", key,
                        "--body", f"{LINEAR_MARKER_PREFIX}{phase}"], check=False)
        return

    # Always go via REST: keeps `flow-progress-set` working out of the box
    # after `jira init`, with no per-dev `~/.config/.jira/.config.yml` edit.
    fid = cfg.jira.field_id(JIRA_FIELD_NAME)
    cfg.jira.put(f"/rest/api/3/issue/{key}", {"fields": {fid: {"value": phase}}})


def cmd_plan(cfg: Config, args: argparse.Namespace) -> None:
    """Resolve a plan path for KEY:
    1. If a plan file matches `_plans/<KEY>-*.md` in the current tree, echo it.
    2. If a sibling branch ending in `-KEY` has one in git, `git show` it to
       a tmpfile under /tmp and echo that path.
    3. Otherwise echo the canonical path the script would create
       (`_plans/<KEY>-<slug>.md`), using TITLE if given, else the tracker title.
    """
    if cfg.repo_root is None:
        die("plan: requires being inside a git repository (plans live in <repo>/_plans/)")
    positionals = list(args.args)
    if positionals and is_key(positionals[0]):
        key = positionals.pop(0)
    else:
        key = require_key(None)
    title = positionals[0] if positionals else ""

    _gc_temp_plans()

    # 1. In current tree.
    existing = _find_existing_plan(cfg, key)
    if existing:
        print(existing)
        return

    # 2. On another branch.
    cross = _plan_from_branch(cfg, key)
    if cross:
        print(cross)
        return

    # 3. Generate a canonical path.
    if not title:
        title = title_for_key(cfg, key)
    slug = slugify(title) or "your-description-slug"
    log(f"no existing plan file for {key} - canonical path follows:")
    print(f"_plans/{key}-{slug}.md")


def _find_existing_plan(cfg: Config, key: str) -> str | None:
    plans_dir = cfg.repo_root / "_plans"
    if not plans_dir.is_dir():
        return None
    matches = sorted(plans_dir.glob(f"{key}-*.md"))
    if not matches:
        return None
    if len(matches) > 1:
        names = " ".join(str(m.relative_to(cfg.repo_root)) for m in matches)
        die(f"multiple plan files match {key}-*.md: {names}")
    return str(matches[0].relative_to(cfg.repo_root))


def _plan_from_branch(cfg: Config, key: str) -> str | None:
    """Look for a plan on a sibling branch ending in `-<KEY>`. Returns the
    tmpfile path it extracted to, or None if no branch / no file matches.
    """
    try:
        out = subprocess.check_output(
            ["git", "branch", "-a", "--format=%(refname:short)"],
            stderr=subprocess.DEVNULL, text=True, cwd=cfg.repo_root)
    except subprocess.CalledProcessError:
        return None
    refs = sorted({line for line in out.splitlines() if re.search(rf"-{re.escape(key)}$", line)})
    if not refs:
        return None
    unique_names = sorted({re.sub(r"^[^/]+/[^/]+/", "", r) for r in refs})
    if len(unique_names) > 1:
        die(f"multiple branches end with -{key}: {' '.join(unique_names)}")
    # Prefer local ref over remote.
    ref = next((r for r in refs if not r.startswith("remotes/")), refs[0])
    try:
        listing = subprocess.check_output(
            ["git", "ls-tree", "-r", "--name-only", ref, "--", "_plans"],
            stderr=subprocess.DEVNULL, text=True, cwd=cfg.repo_root)
    except subprocess.CalledProcessError:
        return None
    rel = next((p for p in listing.splitlines()
                if re.match(rf"^_plans/{re.escape(key)}-.*\.md$", p)), None)
    if not rel:
        return None
    tmp = Path(f"/tmp/plan-{key}-{os.getpid()}.md")
    try:
        content = subprocess.check_output(
            ["git", "show", f"{ref}:{rel}"], text=True, cwd=cfg.repo_root)
    except subprocess.CalledProcessError as e:
        die(f"git show {ref}:{rel} failed: {e}")
    tmp.write_text(content)
    return str(tmp)


def _gc_temp_plans() -> None:
    """Best-effort cleanup of plan tmpfiles older than 1h."""
    cutoff = time.time() - 3600
    for p in Path("/tmp").glob("plan-*-*.md"):
        try:
            if p.is_file() and p.stat().st_mtime < cutoff:
                p.unlink()
        except OSError:
            pass


def cmd_rest(cfg: Config, args: argparse.Namespace) -> None:
    data = args.data
    if args.data_file:
        p = Path(args.data_file)
        if not p.is_file():
            die("rest: --data-file path not found")
        data = p.read_text()
    body = cfg.jira.request(args.method, args.path, raw_body=data or None)
    if body is None:
        return
    if isinstance(body, (dict, list)):
        print(json.dumps(body))
    else:
        print(body)


def cmd_field_id(cfg: Config, args: argparse.Namespace) -> None:
    print(cfg.jira.field_id(args.name))


def cmd_branch_name(cfg: Config, args: argparse.Namespace) -> None:
    """Echo a `<slug>-<KEY>` branch name for the given KEY. Used by
    _team_bin/worktree.sh when minting a worktree.
    """
    key = require_key(args.key)
    title = title_for_key(cfg, key)
    if not title:
        die(f"branch-name: could not resolve title for {key}")
    slug = slugify(title) or "task"
    print(f"{slug}-{key}")


def cmd_list(cfg: Config, args: argparse.Namespace) -> None:
    if args.limit < 1:
        die(f"list: --limit must be a positive integer (got '{args.limit}')")

    # Fuzzy parent resolution mirrors `tasks create`: KEY-shaped -> verbatim,
    # anything else gets matched against cached epic summaries.
    parent = args.parent
    if parent and not is_key(parent):
        resolved = resolve_parent_fuzzy(cfg, parent)
        log(f"matched --parent '{parent}' -> {resolved}")
        parent = resolved

    # Translate canonical Linear-style status names -> JIRA names so
    # `--status "In Review"` works regardless of which backend you came from.
    mapped_statuses: list[str] = []
    for s in args.status:
        if not s:
            die("list: --status requires a non-empty value")
        mapped_statuses.append(JIRA_STATUS_MAP.get(s, s))

    cli_args = ["issue", "list", "--plain", "--no-headers",
                "--columns", "KEY,STATUS,SUMMARY",
                "--paginate", f"0:{args.limit}",
                # Pull rows newest-modified first (`--order-by updated`
                # defaults to DESC). We then group by status in Python, which
                # preserves this newest-first order within each status.
                "--order-by", "updated"]
    if parent:
        cli_args += ["-P", parent]
    if mapped_statuses:
        for s in mapped_statuses:
            cli_args += ["-s", s]
    else:
        # No explicit --status: list only open work. `statusCategory != Done`
        # drops the Done category; Cancelled is miscategorized as "To Do" in
        # this instance, so exclude it by name too.
        cli_args += ["-q", 'statusCategory != Done AND status != Cancelled']

    r = jira_cli(cfg, cli_args, capture=True)
    if r.returncode != 0:
        sys.stderr.write(r.stderr or "")
        die(f"list: jira-cli exited {r.returncode}")
    rows = [ln for ln in (r.stdout or "").splitlines() if ln.strip()]
    # Stable sort by workflow status order. Rows arrive newest-modified first,
    # and a stable sort keeps that ordering within each status group.
    rows.sort(key=_status_rank)
    for ln in rows:
        print(ln)


def _status_rank(row: str) -> int:
    """Rank a `KEY\\tSTATUS\\tSUMMARY` row by workflow status order."""
    parts = row.split("\t")
    status = parts[1].strip() if len(parts) > 1 else ""
    try:
        return STATUS_SORT_ORDER.index(status)
    except ValueError:
        return len(STATUS_SORT_ORDER)


def cmd_epics(cfg: Config, args: argparse.Namespace) -> None:
    epics = cfg.jira.load_epics(force=args.refresh)
    for e in epics:
        print(f"{e['key']}\t{e['summary']}")


def cmd_create(cfg: Config, args: argparse.Namespace) -> None:
    if cfg.task_system != "jira":
        die("create: not yet implemented for linear backend (TBD)")

    # 1. type allow-list
    if args.type not in VALID_ISSUE_TYPES:
        die(f"create: --type must be one of {' '.join(VALID_ISSUE_TYPES)} (got '{args.type}')")

    # 2. attachment pre-flight (so a bad path can't leave an orphan issue)
    attachments = [Path(p) for p in args.attach]
    for p in attachments:
        if not str(p):
            die("create: --attach requires a path")
        if not p.is_file():
            die(f"create: --attach path not found: {p}")
        if p.stat().st_size == 0:
            die(f"create: --attach file is empty: {p}")

    # 3. body file
    body_path: Path | None = None
    if args.from_file:
        body_path = Path(args.from_file)
        if not body_path.is_file():
            die(f"create: --from-file path not found: {body_path}")

    # 4. parent resolution.
    parent = args.parent
    if parent and not is_key(parent):
        resolved = resolve_parent_fuzzy(cfg, parent)
        log(f"matched --parent '{parent}' -> {resolved}")
        parent = resolved
    if not parent:
        if args.type == "Sub-task":
            die("create: --parent KEY is required for Sub-task")
        parent = resolve_default_parent(cfg)

    # 5. create via jira-cli (handles plaintext -> ADF conversion for free).
    # Always go through `--template - --no-input` and feed the body (or empty
    # string for no-body) on stdin. Never use `-b ''` - jira-cli treats an
    # empty `-b` as "not provided" and falls back to $EDITOR/stdin, which
    # then errors as `read /dev/stdin: file already closed` under --no-input.
    log(f"creating {args.type} under {parent}: {args.title}")
    stdin_text = body_path.read_text() if body_path else ""
    r = jira_cli(cfg, ["issue", "create", f"-t{args.type}", "-s", args.title,
                       "-P", parent, "--template", "-", "--no-input"],
                 stdin=stdin_text, capture=True)
    combined = (r.stdout or "") + (r.stderr or "")
    if r.returncode != 0:
        die(f"create: jira-cli failed: {combined}")
    # Anchor key parsing to `browse/<KEY>` so we don't accidentally pick up
    # the parent key from a banner line.
    m_matches = re.findall(r"browse/([A-Z]+-[0-9]+)", combined)
    if not m_matches:
        die(f"create: could not parse key from jira-cli output: {combined}")
    key = m_matches[-1]

    # 6. attachments (sequential, best-effort, exit non-zero on any failure).
    failed: list[str] = []
    for p in attachments:
        if not cfg.jira.attach(key, p):
            failed.append(str(p))
    if failed:
        die(f"create: {key} was created but these attachments failed: {' '.join(failed)}")

    # TTY: print the clickable URL for the human. Captured: print just the
    # KEY so `$(tasks create ...)` keeps working as a key-producing command.
    if sys.stdout.isatty():
        print(f"{cfg.jira_site.rstrip('/')}/browse/{key}")
    else:
        print(key)


def cmd_phases(_cfg: Config | None, _args: argparse.Namespace) -> None:
    for p in PHASES:
        print(p)


HELP_TEXT = """Usage: tasks <subcommand> [args]

Subcommands:
  show              [KEY]                       Print issue details
  comment           [KEY] (BODY | --from-file P) Post a comment (rarely needed; prefer editing the description)
  get-description   [KEY]                       Print the current description as markdown (read before editing)
  set-description   [KEY] (BODY | --from-file P) Replace the description (markdown; fetch + fold in current first)
  create            [--type T] [--parent K] [--from-file P] [--attach P ...] TITLE
                                                JIRA-only: create an issue; echoes the new key
  list              [--parent K] [--status S ...] [--limit N]
                                                JIRA-only: list issues (KEY<TAB>STATUS<TAB>SUMMARY); --parent accepts fuzzy.
                                                Defaults to open issues (hides Done/Cancelled), grouped by status order
                                                (In Progress, In Review, To Do, Backlog) and newest-modified first within
                                                each; pass --status to override the open-only filter.
  set-state         [KEY] STATE                  Transition status (Linear-style name)
  flow-progress-get [KEY]                       Echo current phase or empty
  flow-progress-set [KEY] PHASE                 Advance phase (Requirements|Plan|Code|Close|Done)
  plan              [KEY] [TITLE]               Existing plan path (tree or branch) or canonical new one
  rest              METHOD PATH [--data JSON]   JIRA-only authenticated REST passthrough
  field-id          NAME                        JIRA-only custom-field name -> id (cached 24h)
  epics             [--refresh]                 JIRA-only: list cached epics (KEY<TAB>SUMMARY); 24h TTL
  branch-name       KEY                         Echo a slug-<KEY> branch name (uses the issue title)
  phases                                        List canonical phase names
  help                                          This help text

KEY is auto-derived from the current branch (matches [A-Z]+-[0-9]+) when omitted.
Config: `task-system` resolved from <repo>/project-config.toml, then
~/.config/tasks/config.toml, then defaults to "jira". Works outside any
git repo (plan and branch-derived KEY require being in one).
Auth: JIRA_API_TOKEN from env, else macOS keychain
(`security add-generic-password -s jira-api-token -a $USER -w '<TOKEN>'`).
Errors go to stdout: colored on a TTY, `[[Error: ...]]` marker form when captured.
"""


def cmd_help(_cfg: Config | None = None, _args: argparse.Namespace | None = None) -> None:
    print(HELP_TEXT, end="")

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------


class _TasksParser(argparse.ArgumentParser):
    """ArgumentParser that routes errors through `die()` so we keep the
    `[[Error: ...]]` / colored-TTY contract. The default `error()` prints a
    `usage:` line to stderr before exiting, which leaks into $()-capture.
    """

    def error(self, message: str) -> NoReturn:  # type: ignore[override]
        die(message)


def build_parser() -> argparse.ArgumentParser:
    p = _TasksParser(
        prog="tasks", description="Tracker-agnostic dispatcher",
        add_help=False)
    sub = p.add_subparsers(dest="cmd", parser_class=_TasksParser)

    p_show = sub.add_parser("show", add_help=False)
    p_show.add_argument("key", nargs="?")

    p_comment = sub.add_parser("comment", add_help=False)
    p_comment.add_argument("args", nargs="*")
    p_comment.add_argument("--from-file", dest="from_file", default="")

    p_getdesc = sub.add_parser("get-description", add_help=False)
    p_getdesc.add_argument("key", nargs="?")

    p_setdesc = sub.add_parser("set-description", add_help=False)
    p_setdesc.add_argument("args", nargs="*")
    p_setdesc.add_argument("--from-file", dest="from_file", default="")

    p_create = sub.add_parser("create", add_help=False)
    p_create.add_argument("--type", default="Task")
    p_create.add_argument("--parent", default="")
    p_create.add_argument("--from-file", dest="from_file", default="")
    p_create.add_argument("--attach", action="append", default=[])
    p_create.add_argument("title")

    p_list = sub.add_parser("list", add_help=False)
    p_list.add_argument("--parent", default="")
    p_list.add_argument("--status", action="append", default=[])
    p_list.add_argument("--limit", type=int, default=100)

    p_set = sub.add_parser("set-state", add_help=False)
    p_set.add_argument("args", nargs="*")

    p_fpg = sub.add_parser("flow-progress-get", add_help=False)
    p_fpg.add_argument("key", nargs="?")

    p_fps = sub.add_parser("flow-progress-set", add_help=False)
    p_fps.add_argument("args", nargs="*")

    p_plan = sub.add_parser("plan", add_help=False)
    p_plan.add_argument("args", nargs="*")

    p_rest = sub.add_parser("rest", add_help=False)
    p_rest.add_argument("method")
    p_rest.add_argument("path")
    p_rest.add_argument("--data", default="")
    p_rest.add_argument("--data-file", dest="data_file", default="")

    p_field = sub.add_parser("field-id", add_help=False)
    p_field.add_argument("name")

    p_epics = sub.add_parser("epics", add_help=False)
    p_epics.add_argument("--refresh", action="store_true")

    p_branch = sub.add_parser("branch-name", add_help=False)
    p_branch.add_argument("key", nargs="?")

    sub.add_parser("phases", add_help=False)
    sub.add_parser("help", add_help=False)
    sub.add_parser("-h", add_help=False)
    sub.add_parser("--help", add_help=False)

    return p


HANDLERS: dict[str, Any] = {
    "show": cmd_show,
    "comment": cmd_comment,
    "get-description": cmd_get_description,
    "set-description": cmd_set_description,
    "create": cmd_create,
    "list": cmd_list,
    "set-state": cmd_set_state,
    "flow-progress-get": cmd_flow_progress_get,
    "flow-progress-set": cmd_flow_progress_set,
    "plan": cmd_plan,
    "rest": cmd_rest,
    "field-id": cmd_field_id,
    "epics": cmd_epics,
    "branch-name": cmd_branch_name,
}


def main(argv: list[str]) -> None:
    if not argv:
        cmd_help()
        sys.exit(1)

    sub = argv[0]
    # phases / help don't need config or a git repo.
    if sub == "phases":
        for p in PHASES:
            print(p)
        return
    if sub in ("help", "-h", "--help"):
        cmd_help()
        return

    parser = build_parser()
    args = parser.parse_args(argv)

    handler = HANDLERS.get(sub)
    if handler is None:
        die(f"unknown subcommand '{sub}' (run 'tasks help')")

    cfg = load_config()
    handler(cfg, args)


if __name__ == "__main__":
    main(sys.argv[1:])
